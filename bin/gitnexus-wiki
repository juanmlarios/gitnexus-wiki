#!/usr/bin/env bash
# Self-bootstrapping entrypoint for gitnexus-wiki.
# Creates an isolated venv on first run, then re-execs into it.
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

if [ ! -x "$HERE/.venv/bin/python" ]; then
  echo "[gitnexus-wiki] First-run setup: creating venv at $HERE/.venv ..." >&2
  if command -v uv >/dev/null 2>&1; then
    (cd "$HERE" && uv venv .venv >/dev/null 2>&1 && uv pip install --quiet -e .)
  else
    python3 -m venv "$HERE/.venv"
    "$HERE/.venv/bin/pip" install --quiet --upgrade pip
    "$HERE/.venv/bin/pip" install --quiet -e "$HERE"
  fi
fi

# Always run from the user's CWD so the tool sees the right .gitnexus/ dir.
exec "$HERE/.venv/bin/python" -m wiki "$@"
